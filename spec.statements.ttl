    spec:consideration <https://jeswr.github.io/solid-sparql-query/#security> ;
    spec:requirement
        <#ACSQ-LOC-1> , <#ACSQ-LOC-2> , <#ACSQ-LOC-3> , <#ACSQ-LOC-4> ,
        <#ACSQ-DISC-1> , <#ACSQ-DISC-2> , <#ACSQ-DISC-3> , <#ACSQ-DISC-4> ,
        <#ACSQ-OP-1> , <#ACSQ-OP-2> , <#ACSQ-OP-3> , <#ACSQ-OP-4> , <#ACSQ-OP-5> ,
        <#ACSQ-V12-1> , <#ACSQ-V12-2> ,
        <#ACSQ-CACHE-1> ,
        <#ACSQ-RG-1> , <#ACSQ-RG-2> , <#ACSQ-RG-3> ,
        <#ACSQ-EDG-1> ,
        <#ACSQ-FLAT-1> , <#ACSQ-FLAT-2> ,
